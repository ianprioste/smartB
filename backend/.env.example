# Core
DEBUG=False
PROJECT_NAME="smartBling v2"
VERSION=0.1.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartbling

# Redis
REDIS_URL=redis://localhost:6379/0

# Bling OAuth2
BLING_CLIENT_ID=your_client_id_here
BLING_CLIENT_SECRET=your_client_secret_here
BLING_REDIRECT_URI=http://localhost:8000/auth/bling/callback

# JWT (internal)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://191.252.204.67

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging
LOG_LEVEL=INFO
